{
  "name": "fish-docs",
  "version": "1.0.0",
  "description": "Documentation for products offered by Fish Audio",
  "author": "",
  "scripts": {
    "dev": "mint dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "update:openapi": "node scripts/update-openapi.mjs",
    "check:openapi": "mint openapi-check api-reference/openapi.json",
    "validate": "npm run update:openapi && mint validate"
  },
  "dependencies": {
    "mint": "^4.2.177"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
